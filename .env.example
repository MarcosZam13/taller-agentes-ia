# .env.example — Copiar a .env y completar con tus credenciales
# NO subir .env a GitHub (está en .gitignore)

# ── Proveedor de modelo (elegir UNO) ─────────────────────────────────────────
# Opción A: Azure OpenAI (requiere aprobación de acceso en portal.azure.com)
# Endpoint: Azure Portal → tu recurso OpenAI → Keys and Endpoint
# Formato: https://<recurso>.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# Opción B: OpenRouter (funciona inmediatamente, sin aprobación)
# Registrarse en https://openrouter.ai → API Keys → Create Key
# Tier gratis incluye gpt-4o-mini con límites de velocidad
OPENROUTER_API_KEY=

# ── Telegram (opcional para caso básico) ─────────────────────────────────────
# Crear bot: hablar con @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Tu ID numérico de Telegram: hablar con @userinfobot
TELEGRAM_ALLOWED_USER_ID=
