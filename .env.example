# .env.example — Copiar a .env y completar con tus credenciales
# NO subir .env a GitHub (está en .gitignore)

# ── Proveedor de modelo ───────────────────────────────────────────────────────
# Opción A (recomendada para el taller): Groq — gratis, ~500 tok/s
# Registrarse en https://groq.com → API Keys
GROQ_API_KEY=

# Opción B: OpenRouter — fallback si Groq falla
# Registrarse en https://openrouter.ai → API Keys → Create Key
OPENROUTER_API_KEY=

# Opción C: Azure OpenAI (requiere suscripción paga + aprobación)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ── Telegram (opcional para caso básico) ─────────────────────────────────────
# Crear bot: hablar con @BotFather en Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Tu ID numérico de Telegram: hablar con @userinfobot
TELEGRAM_ALLOWED_USER_ID=

# ── Memoria semántica con Ollama (opcional, avanzado) ────────────────────────
# Embeddings locales para que la búsqueda de memoria use vectores (no solo
# palabras clave). Requiere Ollama instalado + `ollama pull nomic-embed-text`.
# Atajo: corré `bash setup/setup-memory-ollama.sh` que hace todo solo.
# OJO: la URL va SIN /v1 (el script de chat le agrega /v1 aparte).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
